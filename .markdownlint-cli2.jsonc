{
  "config": {
    "default": true,
    "MD013": false,
    "MD024": {
      "siblings_only": true
    },
    "MD033": {
      "allowed_elements": ["br", "details", "summary", "img"]
    },
    "MD041": true,
    "MD060": false,
    "MD040": false,
    "MD036": false
  },
  "ignores": [
    "**/node_modules/**",
    "vault-core/dist/**",
    "vault-core/packages/*/dist/**",
    ".tessl/**",
    ".context/**",
    ".claude/**",
    ".opencode/**",
    "vault-core/skills/**"
  ]
}
