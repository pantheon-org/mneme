{
  "config": {
    "default": true,
    "MD013": {
      "line_length": 120,
      "code_blocks": false,
      "tables": false
    },
    "MD024": {
      "siblings_only": true
    },
    "MD033": {
      "allowed_elements": ["br", "details", "summary", "img"]
    },
    "MD041": true
  },
  "ignores": [
    "vault-core/node_modules/**",
    "vault-core/dist/**",
    "vault-core/packages/*/dist/**",
    ".tessl/**",
    ".context/**",
    "vault-core/skills/**"
  ]
}
