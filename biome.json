{
  "$schema": "https://biomejs.dev/schemas/2.4.6/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": true
  },
  "formatter": {
    "enabled": true,
    "lineWidth": 100,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "complexity": {
        "useArrowFunction": "error"
      },
      "nursery": {
        "noExcessiveLinesPerFile": {
          "level": "error",
          "options": {
            "maxLines": 110,
            "skipBlankLines": true
          }
        }
      },
      "style": {
        "noRestrictedImports": {
          "level": "error",
          "options": {
            "paths": {
              "jest": "Use bun:test instead of jest",
              "vitest": "Use bun:test instead of vitest",
              "better-sqlite3": "Use bun:sqlite instead of better-sqlite3",
              "@jest/globals": "Use bun:test instead of jest"
            }
          }
        }
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "trailingCommas": "all",
      "semicolons": "always"
    }
  },
  "overrides": [
    {
      "includes": ["vault-core/**/*.ts", "vault-core/**/*.tsx"],
      "linter": {
        "rules": {
          "complexity": {
            "useArrowFunction": "error"
          },
          "nursery": {
            "noExcessiveLinesPerFile": {
              "level": "error",
              "options": {
                "maxLines": 110,
                "skipBlankLines": true
              }
            }
          },
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "paths": {
                  "jest": "Use bun:test instead of jest",
                  "vitest": "Use bun:test instead of vitest",
                  "better-sqlite3": "Use bun:sqlite instead of better-sqlite3",
                  "@jest/globals": "Use bun:test instead of jest"
                }
              }
            }
          }
        }
      }
    }
  ]
}
