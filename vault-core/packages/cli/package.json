{
  "name": "@vault-core/cli",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "vault-cli": "./dist/index.js"
  },
  "scripts": {
    "build": "bunx tsc --build",
    "dev": "bunx tsc --watch",
    "typecheck": "bunx tsc --noEmit",
    "install-global": "ln -sf \"$(pwd)/dist/index.js\" \"$(bun pm bin -g)/vault-cli\""
  },
  "dependencies": {
    "@vault-core/core": "workspace:*",
    "@vault-core/types": "workspace:*",
    "commander": "^14.0.0"
  }
}
