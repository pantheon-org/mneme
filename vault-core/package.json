{
  "name": "vault-core-monorepo",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "bun run --filter='*' build",
    "dev": "bun run --filter='*' dev",
    "test": "bun test",
    "test:bdd": "bun --bun node_modules/.bin/cucumber-js --config cucumber.json",
    "typecheck": "bun run --filter='*' typecheck",
    "install:hooks": "bun run scripts/install-hooks.ts",
    "install:skills": "bun run scripts/install-skills.ts",
    "install:cli": "bun run --cwd packages/cli install-global",
    "lint": "bunx --bun biome check .",
    "lint:fix": "bunx --bun biome check --write .",
    "lint:md": "bunx markdownlint-cli2 \"../**/*.md\" \"#node_modules\" \"#dist\" \"#../.tessl\" \"#../.context\"",
    "lint:md:fix": "bunx markdownlint-cli2 --fix \"../**/*.md\" \"#node_modules\" \"#dist\" \"#../.tessl\" \"#../.context\"",
    "format": "bunx --bun biome format --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@cucumber/cucumber": "^12.7.0",
    "@cucumber/pretty-formatter": "^3.2.0",
    "@types/node": "25.4.0",
    "bun-types": "1.3.10",
    "lefthook": "^2.1.3",
    "markdownlint-cli2": "^0.21.0",
    "tsx": "^4.21.0",
    "typescript": "5.9.3"
  },
  "dependencies": {
    "commander": "14.0.3",
    "sqlite-vec": "0.1.7-alpha.2",
    "yaml": "2.8.2"
  }
}
